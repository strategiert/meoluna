# Convex
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CONVEX_SITE_URL=https://your-project.convex.site

# Clerk (Frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# In Convex Dashboard setzen (Backend/Env):
# ANTHROPIC_API_KEY=sk-ant-...
# PADDLEOCR_URL=http://localhost:8001  (oder Production URL)
#
# --- Sicherheit / neu erforderlich ---
# CLERK_JWT_ISSUER_DOMAIN=https://clerk.meoluna.com   # Issuer für Convex↔Clerk-Auth (convex/auth.config.ts)
# ANALYTICS_HASH_PEPPER=<langer Zufallswert>          # HMAC-Pepper für IP/E-Mail-Pseudonymisierung (Pflicht in Prod)
# PADDLEOCR_API_KEY=<geheim>                           # Server-zu-Server-Key; muss im Railway-OCR-Service gleich gesetzt sein
# ADMIN_ROLE_SECRET=<hochentropes Secret>              # Bootstrap der ersten Admin-Rolle (users.setRole)

# Vercel (api/) Env:
# ELEVENLABS_API_KEY=...          # TTS (optional)
# OPENAI_API_KEY=...              # TTS-Fallback (optional)
# CLERK_JWT_ISSUER_DOMAIN=https://clerk.meoluna.com   # für JWT-Verifikation in api/speak.ts
# INNGEST_SIGNING_KEY=signkey-...  # verifiziert eingehende Inngest-Aufrufe (Pflicht in Prod)
# INNGEST_EVENT_KEY=...            # autorisiert das Senden von Inngest-Events

# PaddleOCR-Service (Railway) Env:
# PADDLEOCR_API_KEY=<geheim>       # identisch zum Convex-Wert oben
# ALLOWED_ORIGINS=https://meoluna.com,https://www.meoluna.com

# Mission Control (Scripts/Docs):
# MISSION_CONTROL_TOKEN=<rotiertes Token>   # NICHT committen; früheres Token wurde offengelegt und muss rotiert werden
