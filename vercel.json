{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/blog", "destination": "https://meoluna.com/blog/", "permanent": true },
    { "source": "/blog/:slug", "destination": "https://meoluna.com/blog/:slug/", "permanent": true },
    { "source": "/about", "destination": "https://meoluna.com/ueber-uns/", "permanent": true },
    { "source": "/contact", "destination": "https://meoluna.com/kontakt/", "permanent": true },
    { "source": "/privacy", "destination": "https://meoluna.com/datenschutz/", "permanent": true },
    { "source": "/imprint", "destination": "https://meoluna.com/impressum/", "permanent": true },
    { "source": "/terms", "destination": "https://meoluna.com/agb/", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/inngest.ts": {
      "maxDuration": 300
    }
  }
}
